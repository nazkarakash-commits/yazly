<div class="yazly-portfolio-grid__inner">
  <div class="yazly-portfolio-grid__header">
    <div class="yazly-portfolio-grid__titles">
      <span class="eyebrow">Our Work</span>
      <h2 class="section-title yazly-portfolio-grid__headline">{{ headline }}</h2>
    </div>

    <div class="yazly-portfolio-grid__filters" role="group" aria-label="Portfolio filters">
      <button
        type="button"
        class="yazly-portfolio-grid__filter active"
        data-portfolio-filter="all"
        aria-pressed="true"
      >
        All
      </button>
      <button type="button" class="yazly-portfolio-grid__filter" data-portfolio-filter="restaurants" aria-pressed="false">
        Restaurants
      </button>
      <button type="button" class="yazly-portfolio-grid__filter" data-portfolio-filter="gyms" aria-pressed="false">
        Gyms
      </button>
      <button type="button" class="yazly-portfolio-grid__filter" data-portfolio-filter="teams" aria-pressed="false">
        Teams
      </button>
      <button type="button" class="yazly-portfolio-grid__filter" data-portfolio-filter="merch" aria-pressed="false">
        Merch
      </button>
    </div>
  </div>

  <div class="yazly-portfolio-grid__grid">
    <article
      class="yazly-portfolio-grid__item yazly-portfolio-grid__item--1"
      data-category="{{ i1_filter }}"
    >
      <div class="yazly-portfolio-grid__media">
        {%- if i1_img != blank -%}
          {{ i1_img | image_url: width: 1600 | image_tag: loading: 'lazy', widths: '400, 800, 1200, 1600', sizes: '(min-width: 990px) 45vw, 50vw', alt: i1_title }}
        {%- else -%}
          <div class="yazly-portfolio-grid__placeholder">
            <svg class="yazly-portfolio-grid__placeholder-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.25"/>
              <circle cx="8.5" cy="10" r="1.5" fill="currentColor"/>
              <path d="M3 17l5-5 4 4 3-3 6 6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="yazly-portfolio-grid__placeholder-label">{{ i1_title }}</span>
          </div>
        {%- endif -%}
      </div>
      <div class="yazly-portfolio-grid__overlay">
        <div class="yazly-portfolio-grid__overlay-inner">
          <p class="yazly-portfolio-grid__overlay-cat">{{ i1_cat }}</p>
          <p class="yazly-portfolio-grid__overlay-title">{{ i1_title }}</p>
        </div>
      </div>
    </article>

