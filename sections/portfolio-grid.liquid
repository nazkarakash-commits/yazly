{% stylesheet %}
  .yazly-portfolio-grid-section {
    background-color: var(--color-white);
    padding: var(--section-padding) 0;
  }

  .yazly-portfolio-grid__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    padding: 0 var(--container-padding);
  }

  .yazly-portfolio-grid__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .yazly-portfolio-grid__headline {
    margin: 0;
  }

  .yazly-portfolio-grid__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .yazly-portfolio-grid__filter {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 8px 16px;
    border: 1px solid rgb(0 0 0 / 0.1);
    background: transparent;
    color: var(--color-muted);
    border-radius: 2px;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .yazly-portfolio-grid__filter:hover,
  .yazly-portfolio-grid__filter.active {
    background-color: var(--color-black);
    color: var(--color-white);
    border-color: var(--color-black);
  }

  .yazly-portfolio-grid__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(2, 280px);
    gap: 4px;
  }

  .yazly-portfolio-grid__item {
    position: relative;
    overflow: hidden;
    border-radius: 3px;
    cursor: pointer;
    background-color: #e8e6e1;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .yazly-portfolio-grid__item:hover {
    transform: scale(0.99);
  }

  .yazly-portfolio-grid__item.is-dimmed {
    opacity: 0.3;
    pointer-events: none;
  }

  .yazly-portfolio-grid__item--1 {
    grid-column: 1 / 6;
    grid-row: 1 / 2;
  }

  .yazly-portfolio-grid__item--2 {
    grid-column: 6 / 9;
    grid-row: 1 / 2;
  }

  .yazly-portfolio-grid__item--3 {
    grid-column: 9 / 13;
    grid-row: 1 / 3;
  }

  .yazly-portfolio-grid__item--4 {
    grid-column: 1 / 4;
    grid-row: 2 / 3;
  }

  .yazly-portfolio-grid__item--5 {
    grid-column: 4 / 6;
    grid-row: 2 / 3;
  }

  .yazly-portfolio-grid__item--6 {
    grid-column: 6 / 9;
    grid-row: 2 / 3;
  }

  .yazly-portfolio-grid__media {
    position: absolute;
    inset: 0;
  }

  .yazly-portfolio-grid__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .yazly-portfolio-grid__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    text-align: center;
  }

  .yazly-portfolio-grid__placeholder-icon {
    color: var(--color-muted);
    opacity: 0.45;
  }

  .yazly-portfolio-grid__placeholder-label {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 400;
    color: var(--color-muted);
    line-height: 1.4;
    max-width: 90%;
  }

  .yazly-portfolio-grid__overlay {
    position: absolute;
    inset: 0;
    background: rgb(17 17 17 / 0.72);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .yazly-portfolio-grid__item:hover .yazly-portfolio-grid__overlay {
    opacity: 1;
  }

  .yazly-portfolio-grid__overlay-inner {
    position: absolute;
    left: 0;
    bottom: 0;
    padding: 24px;
    max-width: 100%;
  }

  .yazly-portfolio-grid__overlay-cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-beige);
    margin: 0 0 6px;
  }

  .yazly-portfolio-grid__overlay-title {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-white);
    margin: 0;
    line-height: 1.25;
  }

  .yazly-portfolio-grid__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  .yazly-portfolio-grid__cta {
    margin: 0;
  }

  @media (max-width: 768px) {
    .yazly-portfolio-grid__header {
      flex-direction: column;
      align-items: flex-start;
    }

    .yazly-portfolio-grid__filters {
      justify-content: flex-start;
    }

    .yazly-portfolio-grid__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: none;
      grid-auto-rows: 200px;
    }

    .yazly-portfolio-grid__item--1,
    .yazly-portfolio-grid__item--2,
    .yazly-portfolio-grid__item--3,
    .yazly-portfolio-grid__item--4,
    .yazly-portfolio-grid__item--5,
    .yazly-portfolio-grid__item--6 {
      grid-column: auto;
      grid-row: auto;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    const root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    const buttons = root.querySelectorAll('[data-portfolio-filter]');
    const items = root.querySelectorAll('.yazly-portfolio-grid__item[data-category]');

    function setFilter(filter) {
      buttons.forEach((btn) => {
        const isActive = btn.dataset.portfolioFilter === filter;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      items.forEach((item) => {
        const cat = item.dataset.category;
        let match = true;
        if (filter !== 'all') {
          match = cat === filter || cat === 'all';
        }
        item.classList.toggle('is-dimmed', !match);
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        setFilter(btn.dataset.portfolioFilter);
      });
    });
  })();
</script>

