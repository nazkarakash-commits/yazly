{% liquid
  assign logo_text = section.settings.logo_text | default: 'YAZLY'
  assign cta_label = section.settings.cta_label | default: 'Request a Quote'
  assign cta_url = section.settings.cta_url | default: '/pages/quote'
%}

<header class="site-header" data-site-header>
  <div class="site-header__inner container">
    <a class="site-header__logo" href="{{ routes.root_url }}">{{ logo_text }}</a>

    <nav class="site-header__nav site-header__nav--desktop" aria-label="Primary">
      <a class="site-header__link" href="{{ routes.root_url }}pages/services">Services</a>
      <a class="site-header__link" href="{{ routes.root_url }}pages/portfolio">Portfolio</a>
      <a class="site-header__link" href="{{ routes.root_url }}pages/about">About</a>
      <a class="site-header__link" href="{{ routes.root_url }}pages/process">Process</a>
    </nav>

    <a class="site-header__cta site-header__cta--desktop btn-primary" href="{{ cta_url }}">{{ cta_label }}</a>

    <button
      type="button"
      class="site-header__hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="site-header-menu-{{ section.id }}"
      data-site-header-open
    >
      <span class="site-header__hamburger-line"></span>
      <span class="site-header__hamburger-line"></span>
      <span class="site-header__hamburger-line"></span>
    </button>
  </div>
</header>

<div class="site-header__spacer" aria-hidden="true"></div>

<div
  class="site-header__overlay"
  id="site-header-menu-{{ section.id }}"
  hidden
  data-site-header-overlay
>
  <button
    type="button"
    class="site-header__close"
    aria-label="Close menu"
    data-site-header-close
  >
    ✕
  </button>
  <nav class="site-header__overlay-nav" aria-label="Mobile primary">
    <a class="site-header__overlay-link" href="{{ routes.root_url }}pages/services">Services</a>
    <a class="site-header__overlay-link" href="{{ routes.root_url }}pages/portfolio">Portfolio</a>
    <a class="site-header__overlay-link" href="{{ routes.root_url }}pages/about">About</a>
    <a class="site-header__overlay-link" href="{{ routes.root_url }}pages/process">Process</a>
  </nav>
</div>

{% stylesheet %}
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 68px;
    display: flex;
    align-items: center;
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      backdrop-filter 0.3s ease;
  }

  .site-header.scrolled {
    background-color: rgba(248, 248, 248, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: var(--color-border);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
    max-width: var(--container-width);
    margin-inline: auto;
    padding-inline: var(--container-padding);
    height: 68px;
  }

  .site-header__logo {
    justify-self: start;
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    color: var(--color-white);
    transition: color 0.3s ease;
  }

  .site-header.scrolled .site-header__logo {
    color: var(--color-black);
  }

  .site-header__nav--desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    grid-column: 2;
  }

  .site-header__link {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease;
  }

  .site-header__link:hover {
    color: var(--color-white);
  }

  .site-header.scrolled .site-header__link {
    color: var(--color-muted);
  }

  .site-header.scrolled .site-header__link:hover {
    color: var(--color-black);
  }

  .site-header__cta--desktop {
    justify-self: end;
    grid-column: 3;
    margin: 0;
  }

  .site-header__cta--desktop.btn-primary {
    color: var(--color-black);
    background: var(--color-white);
    transition:
      color 0.3s ease,
      background-color 0.3s ease,
      transform 0.15s ease,
      opacity 0.15s ease;
  }

  .site-header.scrolled .site-header__cta--desktop.btn-primary {
    color: var(--color-white);
    background: var(--color-black);
  }

  .site-header.scrolled .site-header__cta--desktop.btn-primary:hover {
    opacity: 0.88;
  }

  .site-header__hamburger {
    display: none;
    grid-column: 3;
    justify-self: end;
    width: 22px;
    height: 16px;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }

  .site-header__hamburger-line {
    display: block;
    height: 1.5px;
    width: 22px;
    background: var(--color-white);
    border-radius: 1px;
    transition: background-color 0.3s ease;
  }

  .site-header.scrolled .site-header__hamburger-line {
    background: var(--color-black);
  }

  .site-header__spacer {
    height: 68px;
    pointer-events: none;
  }

  .site-header__overlay {
    position: fixed;
    inset: 0;
    z-index: 101;
    background: var(--color-black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .site-header__overlay[hidden] {
    display: none;
  }

  .site-header__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.5rem;
    border: none;
    background: transparent;
    color: var(--color-white);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
  }

  .site-header__overlay-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .site-header__overlay-link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 28px;
    color: var(--color-white);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .site-header__nav--desktop,
    .site-header__cta--desktop {
      display: none;
    }

    .site-header__hamburger {
      display: flex;
    }

    .site-header__inner {
      grid-template-columns: 1fr auto;
    }

    .site-header__logo {
      grid-column: 1;
    }

    .site-header__hamburger {
      grid-column: 2;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    const nav = document.querySelector('.site-header');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    });

    let scrollLockY = 0;
    const overlay = document.querySelector('[data-site-header-overlay]');
    const openBtn = document.querySelector('[data-site-header-open]');
    const closeBtn = document.querySelector('[data-site-header-close]');

    if (nav) {
      nav.classList.toggle('scrolled', window.scrollY > 60);
    }

    if (!overlay || !openBtn) return;

    function lockScroll() {
      scrollLockY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollLockY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.overflow = 'hidden';
    }

    function unlockScroll() {
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.overflow = '';
      window.scrollTo(0, scrollLockY);
    }

    function openMenu() {
      overlay.hidden = false;
      openBtn.setAttribute('aria-expanded', 'true');
      lockScroll();
    }

    function closeMenu() {
      overlay.hidden = true;
      openBtn.setAttribute('aria-expanded', 'false');
      unlockScroll();
    }

    openBtn.addEventListener('click', () => {
      if (overlay.hidden) openMenu();
    });
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeMenu();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hidden) closeMenu();
    });
  })();
</script>

{% schema %}
{
  "name": "Yazly header",
  "tag": "section",
  "class": "yazly-site-header-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "YAZLY"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Request a Quote"
    },
    {
      "type": "text",
      "id": "cta_url",
      "label": "CTA button URL",
      "default": "/pages/quote",
      "info": "Use a relative path (e.g. /pages/quote) or full URL."
    }
  ]
}
{% endschema %}
