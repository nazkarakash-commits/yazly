{% liquid
  assign headline         = section.settings.headline         | default: 'Because First Impressions Matter.'
  assign subheadline      = section.settings.subheadline      | default: 'Yazly helps businesses, creators, and teams create professional branded apparel that strengthens presentation and builds lasting recognition.'
  assign eyebrow_text     = section.settings.eyebrow_text     | default: 'Custom Apparel · Embroidery · Branded Merch'
  assign featured_label   = section.settings.featured_label   | default: 'Featured Work'
  assign featured_project = section.settings.featured_project | default: 'Café Staff Uniforms — Ottawa'
  assign cta_primary_label   = section.settings.cta_primary_label   | default: 'Request a Quote'
  assign cta_primary_url     = section.settings.cta_primary_url     | default: '/pages/quote'
  assign cta_secondary_label = section.settings.cta_secondary_label | default: 'View Our Work'
  assign cta_secondary_url   = section.settings.cta_secondary_url   | default: '#portfolio'
%}

<section class="yazly-hero" aria-label="Hero">

  <div class="yazly-hero__grid-overlay" aria-hidden="true"></div>

  <div class="yazly-hero__inner">

    <!-- Left column -->
    <div class="yazly-hero__left">

      <span class="eyebrow yazly-hero__eyebrow">
        <span class="yazly-hero__eyebrow-line" aria-hidden="true"></span>
        {{- eyebrow_text -}}
      </span>

      <h1 class="yazly-hero__headline">{{ headline }}</h1>

      <p class="yazly-hero__subheadline">{{ subheadline }}</p>

      <div class="yazly-hero__ctas">
        <a href="{{ cta_primary_url }}" class="btn-primary">{{ cta_primary_label }}</a>
        <a href="{{ cta_secondary_url }}" class="btn-secondary">{{ cta_secondary_label }}</a>
      </div>

    </div>

    <!-- Right column -->
    <div class="yazly-hero__right" aria-hidden="true">
      <div class="yazly-hero__image-block">

        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 900 }}"
            alt="{{ section.settings.hero_image.alt | escape }}"
            class="yazly-hero__image"
            loading="eager"
            width="{{ section.settings.hero_image.width }}"
            height="{{ section.settings.hero_image.height }}"
          >
        {%- else -%}
          <div class="yazly-hero__placeholder">
            <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="2" y="7" width="40" height="30" rx="2.5" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
              <circle cx="14" cy="18" r="3.5" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
              <path d="M2 31l10-9 7 7 6-5 9 9" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
            <span class="yazly-hero__placeholder-text">Your hero image here</span>
          </div>
        {%- endif -%}

        <div class="yazly-hero__tag">
          <span class="yazly-hero__tag-label">{{ featured_label }}</span>
          <span class="yazly-hero__tag-project">{{ featured_project }}</span>
        </div>

      </div>
    </div>

  </div>

  <div class="yazly-hero__scroll" aria-hidden="true">
    <span class="yazly-hero__scroll-text">Scroll</span>
    <span class="yazly-hero__scroll-line"></span>
  </div>

</section>

<style>
  @keyframes yazlyFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section shell ── */
  .yazly-hero {
    --hero-image-bg: #1d1d1d;
    position: relative;
    min-height: 100vh;
    background-color: var(--color-black);
    display: flex;
    flex-direction: column;
    justify-content: center;
    /* Pull up to compensate for the 68px spacer header.liquid injects into flow.
       Uses --header-height set dynamically on body by theme.liquid's inline script. */
    margin-top: calc(-1 * var(--header-height, 68px));
  }

  /* ── CSS grid pattern overlay ── */
  .yazly-hero__grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.025) 0px,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px,
        transparent 80px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.025) 0px,
        rgba(255, 255, 255, 0.025) 1px,
        transparent 1px,
        transparent 80px
      );
  }

  /* ── Two-column inner grid ── */
  .yazly-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 120px 40px 80px;
    display: grid;
    grid-template-columns: 55fr 45fr;
    gap: 60px;
    align-items: center;
  }

  /* ── Eyebrow ── */
  .yazly-hero__eyebrow {
    color: var(--color-beige);
    display: flex;
    align-items: center;
    gap: 14px;
    animation: yazlyFadeUp 0.8s ease 0.2s both;
  }

  .yazly-hero__eyebrow-line {
    display: inline-block;
    flex-shrink: 0;
    width: 32px;
    height: 1px;
    background-color: var(--color-beige);
  }

  /* ── Headline ── */
  .yazly-hero__headline {
    font-family: var(--font-display);
    font-size: clamp(38px, 5.5vw, 72px);
    font-weight: 500;
    color: var(--color-white);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 24px;
    animation: yazlyFadeUp 0.8s ease 0.35s both;
  }

  /* ── Subheadline ── */
  .yazly-hero__subheadline {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 300;
    color: rgba(248, 248, 248, 0.55);
    line-height: 1.75;
    max-width: 460px;
    margin: 0 0 40px;
    animation: yazlyFadeUp 0.8s ease 0.5s both;
  }

  /* ── CTA row ── */
  .yazly-hero__ctas {
    display: flex;
    align-items: center;
    gap: 14px;
    animation: yazlyFadeUp 0.8s ease 0.65s both;
  }

  /* ── Image block ── */
  .yazly-hero__image-block {
    position: relative;
    height: 480px;
    background: var(--hero-image-bg);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 4px;
    overflow: hidden;
  }

  .yazly-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Placeholder state ── */
  .yazly-hero__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .yazly-hero__placeholder-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.2);
  }

  /* ── Overlay tag ── */
  .yazly-hero__tag {
    position: absolute;
    bottom: 16px;
    left: 16px;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    padding: 10px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .yazly-hero__tag-label {
    display: block;
    font-family: var(--font-display);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .yazly-hero__tag-project {
    display: block;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-white);
  }

  /* ── Scroll indicator ── */
  .yazly-hero__scroll {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .yazly-hero__scroll-text {
    font-family: var(--font-display);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.3);
  }

  .yazly-hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0.3), transparent);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .yazly-hero__inner {
      grid-template-columns: 1fr;
      padding: 100px 24px 80px;
      gap: 0;
    }

    .yazly-hero__right {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Yazly Hero",
  "tag": "section",
  "class": "yazly-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Because First Impressions Matter."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Yazly helps businesses, creators, and teams create professional branded apparel that strengthens presentation and builds lasting recognition."
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Custom Apparel · Embroidery · Branded Merch"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "featured_label",
      "label": "Featured label",
      "default": "Featured Work"
    },
    {
      "type": "text",
      "id": "featured_project",
      "label": "Featured project name",
      "default": "Café Staff Uniforms — Ottawa"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Request a Quote"
    },
    {
      "type": "text",
      "id": "cta_primary_url",
      "label": "Primary CTA URL",
      "default": "/pages/quote",
      "info": "Use a relative path (e.g. /pages/quote) or full URL."
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "View Our Work"
    },
    {
      "type": "text",
      "id": "cta_secondary_url",
      "label": "Secondary CTA URL",
      "default": "#portfolio",
      "info": "Supports anchor links (e.g. #portfolio) or relative paths."
    }
  ]
}
{% endschema %}
